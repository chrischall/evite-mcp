# evite-mcp configuration
# Copy to `.env` and fill in real values for local dev (`npm run dev`).

# --- Tier-1: email/password login (preferred) ---
# When both are set, the server logs in headlessly via POST /ajax_login and
# builds the session from the response cookies — no browser bridge, no
# hand-copied cookie. Both must be set, or the resolver falls through to the
# tiers below.
# EVITE_EMAIL=you@example.com
# EVITE_PASSWORD=your-password

# A raw `cookie:` header copied from a signed-in evite.com browser tab. When
# set (and no email/password), this is used verbatim and the fetchproxy browser
# bridge is skipped — the simplest path for headless / CI use. Must include the
# session cookies (x-evite-session, evtsession).
# EVITE_SESSION_COOKIE=x-evite-session=...; evtsession=...

# Set to "true" to disable the fetchproxy browser bridge. With the bridge
# disabled you MUST provide EVITE_EMAIL/EVITE_PASSWORD or EVITE_SESSION_COOKIE.
# Defaults to false.
# EVITE_DISABLE_FETCHPROXY=false
